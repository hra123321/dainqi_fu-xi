# ========== Python 通用忽略规则 ==========
# __pycache__ 是 Python 运行后自动生成的字节码缓存目录
# 每个人本地运行都会生成，不需要提交到 Git
__pycache__/
*.py[cod]
*.pyo

# ========== 虚拟环境 ==========
# venv/ 或 .venv/ 是 Python 虚拟环境目录
# 里面装了所有依赖包，体积很大，每人在自己电脑上装就行
venv/
.venv/
env/

# ========== 项目配置文件 ==========
# .env 存放 API Key、数据库密码等敏感信息
# 绝对不能上传到 GitHub！每个人本地自己创建
.env

# ========== IDE 编辑器配置 ==========
# 每个人用的编辑器不同，这些配置只属于你的本地环境
.idea/
.vscode/
*.swp
*.swo

# ========== 向量数据库文件 ==========
# Chroma 生成的 SQLite 数据库文件，体积大且是本地生成的
data/vector_db/
data/app.sqlite3
data/backups/

# ========== 操作系统文件 ==========
# Windows 资源管理器生成的缩略图/元数据文件
Thumbs.db
.DS_Store

# ========== 项目运行时生成 ==========
# 日志文件每次运行都会生成新的
data/logs/
*.log

# 测试临时文件
_gen.py
_test_*.txt
_test_*.py
stdout.txt
stderr.txt

# Temporary fix scripts
fix_*.py
check_*.py
debug_*.py
prepare_kb.py
import_kb.py
